  <!-- ─── JOURNEY MOTION LAYER ──────────────────────────────────────────────── -->
  <style is:global>
    /* Hero background: drifting gradient */
    .hero-bg {
      background: linear-gradient(135deg, hsl(243,75%,18%) 0%, hsl(243,75%,34%) 60%, hsl(260,70%,40%) 100%);
    }
    .hero-blob {
      position: absolute; border-radius: 9999px; filter: blur(80px); opacity: .3; pointer-events: none;
    }
    .hero-blob-1 { width: 26rem; height: 26rem; background: hsl(260 80% 55%); top: -8rem; right: -6rem; }
    .hero-blob-2 { width: 22rem; height: 22rem; background: hsl(230 80% 50%); bottom: -10rem; left: -7rem; }

    /* Rotating hero keyword */
    .rotate-word {
      display: inline-block; color: #fcd34d; white-space: nowrap;
      transition: opacity .25s ease, transform .25s ease;
    }
    .rotate-word.swap { opacity: 0; transform: translateY(0.5em); }

    /* Phone mockup */
    .phone {
      position: relative; width: 288px; height: 560px; border-radius: 2.7rem;
      background: #111827; padding: 12px; box-shadow: 0 35px 70px -18px rgba(0,0,0,.55);
      outline: 1px solid rgba(255,255,255,.18);
    }
    .phone-notch {
      position: absolute; top: 22px; left: 50%; transform: translateX(-50%);
      width: 92px; height: 17px; border-radius: 9999px; background: #111827; z-index: 20;
    }
    .phone-screen {
      display: flex; flex-direction: column; height: 100%; overflow: hidden;
      border-radius: 2rem; background: #eef0f4;
    }
    .phone-map {
      background-color: #eaecf1;
      background-image:
        linear-gradient(rgba(255,255,255,.85) 2px, transparent 2px),
        linear-gradient(90deg, rgba(255,255,255,.85) 2px, transparent 2px),
        linear-gradient(rgba(255,255,255,.5) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.5) 1px, transparent 1px);
      background-size: 72px 72px, 72px 72px, 24px 24px, 24px 24px;
    }
    .pin-pickup {
      position: absolute; left: 40px; bottom: 30px; width: 12px; height: 12px;
      border-radius: 9999px; background: #22c55e; box-shadow: 0 0 0 4px rgba(34,197,94,.25);
    }
    .pin-drop { position: absolute; right: 34px; top: 32px; }

    /* FAQ answer slide-in */
    .faq-item[open] > p { animation: faqOpen .35s ease; }
    @keyframes faqOpen { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: none; } }

    /* Nav scrolled state */
    #site-nav.scrolled { box-shadow: 0 10px 30px -10px rgba(0,0,0,.5); backdrop-filter: blur(8px); }

    @media (prefers-reduced-motion: no-preference) {
      /* Drifting hero gradient + blobs */
      .hero-bg { background-size: 180% 180%; animation: gradientDrift 16s ease-in-out infinite alternate; }
      @keyframes gradientDrift { from { background-position: 0% 0%; } to { background-position: 100% 100%; } }
      .hero-blob-1 { animation: blobDrift 20s ease-in-out infinite alternate; }
      .hero-blob-2 { animation: blobDrift 24s ease-in-out infinite alternate-reverse; }
      @keyframes blobDrift { from { transform: translate(0,0) scale(1); } to { transform: translate(-3rem,2.5rem) scale(1.15); } }

      /* Hero entrance stagger (only when JS is present, so no-JS users see content) */
      html.js .hero-enter { opacity: 0; animation: heroIn .7s cubic-bezier(.22,.8,.35,1) forwards; }
      html.js .d1 { animation-delay: .05s } html.js .d2 { animation-delay: .17s }
      html.js .d3 { animation-delay: .29s } html.js .d4 { animation-delay: .41s }
      html.js .d5 { animation-delay: .55s }
      @keyframes heroIn { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }

      /* Phone float */
      .phone { animation: phoneFloat 6s ease-in-out infinite; }
      @keyframes phoneFloat { 0%,100% { transform: translateY(0) rotate(.4deg); } 50% { transform: translateY(-14px) rotate(-.4deg); } }
      .driver-card { animation: cardIn .8s cubic-bezier(.22,.8,.35,1) 1.1s backwards; }
      @keyframes cardIn { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: none; } }

      /* Scroll reveals */
      html.js [data-reveal] { opacity: 0; transform: translateY(26px); transition: opacity .65s ease, transform .65s cubic-bezier(.22,.8,.35,1); }
      html.js [data-reveal].revealed { opacity: 1; transform: none; }

      /* Card lift + icon wiggle */
      .lift-card { transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease, opacity .65s ease; }
      .lift-card:hover { transform: translateY(-5px); box-shadow: 0 18px 35px -12px rgba(79,70,229,.22); border-color: #c7d2fe; }
      .card-icon { transition: transform .3s ease; }
      .lift-card:hover .card-icon, li:hover > .card-icon { animation: iconPop .45s ease; }
      @keyframes iconPop { 0% { transform: scale(1) } 40% { transform: scale(1.18) rotate(-5deg) } 100% { transform: scale(1) } }

      /* Buttons */
      .btn-pop { transition: transform .25s ease, background-color .25s ease, box-shadow .25s ease; }
      .btn-pop:hover { transform: scale(1.04); }
      .btn-sheen { position: relative; overflow: hidden; }
      .btn-sheen::after {
        content: ''; position: absolute; top: 0; left: -80%; height: 100%; width: 55%;
        background: linear-gradient(105deg, transparent, rgba(99,102,241,.16), transparent);
        transform: skewX(-20deg); transition: left .55s ease;
      }
      .btn-sheen:hover::after { left: 130%; }

      /* Step badge pulse when revealed */
      html.js [data-reveal].revealed .step-badge { animation: badgePulse 1s ease .5s; }
      @keyframes badgePulse { 0% { box-shadow: 0 0 0 0 rgba(79,70,229,.55); } 100% { box-shadow: 0 0 0 14px rgba(79,70,229,0); } }
    }

    @media (prefers-reduced-motion: reduce) {
      .route-car, .phone svg text { display: none; }
    }
  </style>

  <script is:inline>
    (function () {
      document.documentElement.classList.add('js');
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      /* Nav shadow/blur after scrolling */
      var nav = document.getElementById('site-nav');
      var onScroll = function () { nav.classList.toggle('scrolled', window.scrollY > 8); };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      /* Scroll reveals */
      var revealEls = document.querySelectorAll('[data-reveal]');
      if (reduce || !('IntersectionObserver' in window)) {
        revealEls.forEach(function (el) { el.classList.add('revealed'); });
      } else {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var el = entry.target;
            var delay = parseInt(el.getAttribute('data-reveal-delay') || '0', 10);
            if (delay) el.style.transitionDelay = delay + 'ms';
            el.classList.add('revealed');
            io.unobserve(el);
            /* after the reveal settles, drop the reveal styles so card hover
               transitions aren't slowed or delayed by them */
            setTimeout(function () {
              el.style.transitionDelay = '';
              el.removeAttribute('data-reveal');
            }, delay + 750);
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
        revealEls.forEach(function (el) { io.observe(el); });
      }

      /* Stat counters */
      var counters = document.querySelectorAll('[data-count]');
      function formatStat(v, format, done) {
        if (format === 'k') return done ? '10K+' : (v >= 1000 ? (v / 1000).toFixed(1) + 'K' : Math.round(v));
        if (format === 'plus') return Math.round(v) + (done ? '+' : '');
        if (format === 'star') return v.toFixed(1) + '★';
        return Math.round(v);
      }
      function runCounter(el) {
        var target = parseFloat(el.getAttribute('data-count'));
        var format = el.getAttribute('data-format');
        var t0 = null, dur = 1400;
        function tick(t) {
          if (!t0) t0 = t;
          var p = Math.min((t - t0) / dur, 1);
          var eased = 1 - Math.pow(1 - p, 3);
          el.textContent = formatStat(target * eased, format, p === 1);
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }
      if (!reduce && 'IntersectionObserver' in window && counters.length) {
        var cio = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            runCounter(entry.target);
            cio.unobserve(entry.target);
          });
        }, { threshold: 0.6 });
        counters.forEach(function (el) { cio.observe(el); });
      }

      /* Rotating hero keyword */
      var wordEl = document.getElementById('rotate-word');
      if (wordEl && !reduce) {
        var words = ['Cabs', 'Bikes', 'Autos', 'Outstation', 'Delivery'];
        var idx = 0;
        setInterval(function () {
          wordEl.classList.add('swap');
          setTimeout(function () {
            idx = (idx + 1) % words.length;
            wordEl.textContent = words[idx];
            wordEl.classList.remove('swap');
          }, 260);
        }, 2600);
      }
    })();
  </script>

