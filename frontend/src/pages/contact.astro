---
import '../styles/globals.css';
import BrandingLogo from '../components/BrandingLogo.astro';
import ContactPage from '../entries/ContactPage';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/favicon-32.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>Contact Us – Zyppi</title>
  <meta name="description" content="Get in touch with the Zyppi team — questions about rides, payments, partnerships or anything else. We usually reply within 24 hours." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://zyppi.in/contact" />
  <meta name="theme-color" content="#673AB7" />
</head>
<body class="bg-white text-gray-900 antialiased">

  <!-- NAV -->
  <header class="sticky top-0 z-50 border-b border-white/10 bg-[hsl(243_75%_22%)] shadow-lg">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-4 sm:px-6">
      <a href="/" class="flex items-center gap-2.5">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-white p-1.5">
          <img src="/logo.png" alt="Zyppi logo" class="h-6 w-6 object-contain" data-branding-logo />
        </div>
        <span class="text-xl font-bold tracking-wide text-white">ZYPPI</span>
      </a>
      <a href="/" class="text-sm text-white/70 hover:text-white transition-colors">← Back to Home</a>
    </div>
  </header>

  <!-- CONTENT -->
  <main class="mx-auto max-w-2xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-indigo-600 mb-2">Support</p>
      <h1 class="text-4xl font-extrabold text-gray-900">Contact Us</h1>
      <p class="mt-3 text-sm text-gray-500">
        Have a question about a ride, payment or partnership? Send us a message and we'll get back to you,
        or email us directly at <a href="mailto:support@zyppiride.com" class="text-indigo-600 hover:underline">support@zyppiride.com</a>.
      </p>
    </div>

    <ContactPage client:only="react" />
  </main>

  <!-- FOOTER -->
  <footer class="border-t border-gray-100 py-8">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 flex flex-col items-center gap-2 text-xs text-gray-400 sm:flex-row sm:justify-between">
      <p>© {new Date().getFullYear()} Zyppi. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/privacy-policy" class="hover:text-gray-600 transition-colors">Privacy Policy</a>
        <a href="/term-condition" class="hover:text-gray-600 transition-colors">Terms</a>
      </div>
    </div>
  </footer>

  <BrandingLogo />
</body>
</html>
