---
import '../../styles/globals.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bookings — Zyppi Admin</title>
</head>
<body class="bg-gray-50">
  <div id="app-root"></div>
  <script>
    import { createRoot } from 'react-dom/client';
    import { createElement } from 'react';
    import { AdminShell } from '../../components/layout/AdminShell';
    import { BookingsShell } from '../../features/bookings/BookingsShell';
    createRoot(document.getElementById('app-root')!).render(
      createElement(AdminShell, { title: 'Bookings', subtitle: 'All ride bookings and history', currentPath: '/bookings' },
        createElement(BookingsShell))
    );
  </script>
</body>
</html>
