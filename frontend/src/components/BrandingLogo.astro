---
// Loads the custom logo from Firestore (settings/branding, public read) and
// swaps it into every <img data-branding-logo> plus the favicon. Pages keep
// the bundled /logo.png as instant fallback, so this is progressive only.
const projectId = import.meta.env.PUBLIC_FIREBASE_PROJECT_ID;
const apiKey = import.meta.env.PUBLIC_FIREBASE_API_KEY;
const url = `https://firestore.googleapis.com/v1/projects/${projectId}/databases/(default)/documents/settings/branding?key=${apiKey}&mask.fieldPaths=logoData`;
---
<script define:vars={{ url }}>
  fetch(url)
    .then((r) => (r.ok ? r.json() : null))
    .then((d) => {
      const v = d && d.fields && d.fields.logoData && d.fields.logoData.stringValue;
      if (!v) return;
      document.querySelectorAll('img[data-branding-logo]').forEach((el) => { el.src = v; });
      document.querySelectorAll('link[rel="icon"], link[rel="apple-touch-icon"]').forEach((el) => { el.href = v; });
    })
    .catch(() => {});
</script>
